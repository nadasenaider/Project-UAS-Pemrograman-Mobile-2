<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivSnackbarIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/dot_inactive"
            android:backgroundTint="@color/primary_gold_transparent"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_save"
            app:tint="@color/primary_gold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSnackbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berhasil Ditambahkan"
                android:textColor="@color/primary_gold"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSnackbarMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Film telah disimpan ke koleksi"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnSnackbarAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:text="OK"
            android:textAllCaps="true"
            android:textColor="@color/text_gold"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
