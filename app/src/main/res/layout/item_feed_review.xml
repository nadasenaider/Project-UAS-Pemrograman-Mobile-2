<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- User avatar placeholder circular -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvUserAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/divider_color"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/primary_gold"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="FR" />
        </androidx.cardview.widget.CardView>

        <!-- User name & Time -->
        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/cvUserAvatar"
            app:layout_constraintTop_toTopOf="@id/cvUserAvatar"
            app:layout_constraintEnd_toStartOf="@id/cvMoviePoster"
            tools:text="Fahri Ramadhan" />

        <TextView
            android:id="@+id/tvTimeAgo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="@id/tvUserName"
            app:layout_constraintTop_toBottomOf="@id/tvUserName"
            app:layout_constraintEnd_toStartOf="@id/cvMoviePoster"
            tools:text="2 hours ago" />

        <!-- Rating bar indicator -->
        <RatingBar
            android:id="@+id/rbReview"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:progressTint="@color/text_gold"
            app:layout_constraintStart_toStartOf="@id/cvUserAvatar"
            app:layout_constraintTop_toBottomOf="@id/cvUserAvatar"
            tools:rating="4.5" />

        <!-- Review Text -->
        <TextView
            android:id="@+id/tvReviewText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cvMoviePoster"
            app:layout_constraintTop_toBottomOf="@id/rbReview"
            android:layout_marginEnd="16dp"
            tools:text="Sinematografi dan scoring dari Ludwig Göransson luar biasa! Cillian Murphy memberikan penampilan terbaik dalam karirnya." />

        <!-- Movie mini card on the right -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvMoviePoster"
            android:layout_width="60dp"
            android:layout_height="90dp"
            app:cardCornerRadius="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivMoviePoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Movie Poster"
                tools:src="@drawable/bg_onboarding" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
