<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="132dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp">

    <!-- Card for Movie Poster -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvPoster"
        android:layout_width="120dp"
        android:layout_height="170dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Movie Poster -->
            <ImageView
                android:id="@+id/ivPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Movie Poster"
                tools:src="@drawable/bg_onboarding" />

            <!-- Rating Badge (Top Left Overlay) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:background="@drawable/dot_active"
                android:backgroundTint="#CC121212"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★"
                    android:textColor="@color/text_gold"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    tools:text="8.2" />
            </LinearLayout>

            <!-- TV Badge (Top Right Overlay) -->
            <TextView
                android:id="@+id/tvTvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_margin="6dp"
                android:background="@drawable/dot_active"
                android:backgroundTint="#CCFFD700"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:text="TV"
                android:textColor="@color/black"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Movie Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/cvPoster"
        app:layout_constraintEnd_toEndOf="@id/cvPoster"
        app:layout_constraintTop_toBottomOf="@id/cvPoster"
        tools:text="Oppenheimer" />

    <!-- Movie Release Year -->
    <TextView
        android:id="@+id/tvYear"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/cvPoster"
        app:layout_constraintEnd_toEndOf="@id/cvPoster"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        tools:text="2023" />

</androidx.constraintlayout.widget.ConstraintLayout>
